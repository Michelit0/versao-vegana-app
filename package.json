{
  "name": "versao-vegana-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit --incremental false",
    "preview": "vite preview",
    "import:xlsx": "python scripts/import_xlsx_to_seed.py",
    "import:production:xlsx": "python scripts/generate_production_import_sql.py",
    "db:apply": "node scripts/apply_sql.mjs",
    "db:restore:production-baseline": "node scripts/restore_production_baseline.mjs",
    "backup:code": "node scripts/create_code_backup.mjs",
    "backup:supabase": "node scripts/export_supabase_backup.mjs",
    "backup:all": "npm run backup:code && npm run backup:supabase",
    "protect:check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
